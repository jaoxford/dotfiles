# nofail = don't halt boot if partition is unavailable
# After adding, run: sudo mkdir -p /mnt/windows && sudo mount /mnt/windows
UUID=22FCF68DFCF65A8D /mnt/windows ntfs3 uid=1000,gid=1000,nofail 0 0

